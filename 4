def parse_resp(data):
    if not data or data[0] != ord(b"*"):
        return None

    parts = data.split(b"\r\n")

    try:
        num_elements = int(parts[0][1:])
        elems = parts[2::2]
    except:
        return None

    # if nothing or len(rest of parts) does not match num_elements
    # return None
    if len(elems) != num_elements:
        return None

    return elems 

